{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReconOutput",
  "description": "Architecture map + initial hunt task queue.",
  "type": "object",
  "required": ["subsystems", "architecture", "initial_tasks"],
  "additionalProperties": false,
  "properties": {
    "subsystems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path", "language", "purpose"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string", "description": "Repo-relative directory or file." },
          "language": { "type": "string" },
          "purpose": { "type": "string" },
          "external_dependencies": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "architecture": {
      "type": "object",
      "required": ["build_commands", "entry_points", "trust_boundaries"],
      "additionalProperties": false,
      "properties": {
        "build_commands": { "type": "array", "items": { "type": "string" } },
        "test_commands":  { "type": "array", "items": { "type": "string" } },
        "entry_points": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "location"],
            "additionalProperties": false,
            "properties": {
              "kind": { "type": "string", "description": "http_route|cli|rpc|grpc|message_queue|cron|library_api|webhook|file_input" },
              "location": { "type": "string", "description": "file:line or symbol reference" },
              "auth_required": { "type": "boolean" },
              "notes": { "type": "string" }
            }
          }
        },
        "trust_boundaries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "source_zone": { "type": "string" },
              "sink_zone": { "type": "string" }
            }
          }
        },
        "external_inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "kind"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "kind": { "type": "string", "description": "http_param|http_header|http_body|env_var|file|cli_arg|stdin|db_field|broker_message" },
              "controllable_by": { "type": "string", "description": "anonymous_user|authenticated_user|admin|internal_service" }
            }
          }
        }
      }
    },
    "initial_tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "hunt_task.schema.json" }
    }
  }
}
