{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Secret Hunter Report",
  "type": "object",
  "required": ["schema_version", "tool", "run_id", "target", "summary", "scanner_runs", "findings"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string" },
    "tool": { "const": "secret-hunter" },
    "run_id": { "type": "string" },
    "target": {
      "type": "object",
      "required": ["repo_path"],
      "additionalProperties": false,
      "properties": {
        "repo_path": { "type": "string" },
        "commit": { "type": ["string", "null"] }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "by_severity", "by_verification", "by_source"],
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "by_severity": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_verification": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_source": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "scanner_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scanner", "status", "command", "artifact_path", "exit_code", "started_at", "finished_at", "error"],
        "additionalProperties": true,
        "properties": {
          "scanner": { "type": "string" },
          "status": { "type": "string", "enum": ["success", "error", "unavailable"] },
          "command": { "type": "array", "items": { "type": "string" } },
          "artifact_path": { "type": ["string", "null"] },
          "exit_code": { "type": ["integer", "null"] },
          "started_at": { "type": "number" },
          "finished_at": { "type": "number" },
          "error": { "type": ["string", "null"] }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "title",
          "severity",
          "sources",
          "detector_name",
          "secret_type",
          "verification",
          "confidence",
          "file",
          "line_start",
          "line_end",
          "commit",
          "fingerprint",
          "redacted_evidence",
          "raw_artifact_paths",
          "ai_analysis"
        ],
        "additionalProperties": false,
        "properties": {
          "finding_id": { "type": "string" },
          "title": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "informational"] },
          "sources": {
            "type": "array",
            "items": { "type": "string", "enum": ["trufflehog", "gitleaks"] },
            "minItems": 1
          },
          "detector_name": { "type": "string" },
          "secret_type": { "type": "string" },
          "verification": {
            "type": "object",
            "required": ["status"],
            "additionalProperties": false,
            "properties": {
              "status": { "type": "string", "enum": ["verified", "unverified", "unknown", "failed", "not_supported"] }
            }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "file": { "type": "string" },
          "line_start": { "type": ["integer", "null"], "minimum": 1 },
          "line_end": { "type": ["integer", "null"], "minimum": 1 },
          "commit": { "type": ["string", "null"] },
          "fingerprint": { "type": "string" },
          "redacted_evidence": { "type": "string" },
          "raw_artifact_paths": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "ai_analysis": {
            "type": "object",
            "required": ["status", "likely_secret_type", "false_positive_likelihood", "confidence", "rationale"],
            "additionalProperties": false,
            "properties": {
              "status": { "type": "string", "enum": ["completed", "disabled", "not_run", "error"] },
              "likely_secret_type": { "type": "string" },
              "false_positive_likelihood": { "type": "string", "enum": ["low", "medium", "high", "unknown"] },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "rationale": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
